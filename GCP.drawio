        <mxCell id="eferr9TLxHA396iQWkDf-64" value="workload-1-ro" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;opacity=50;" vertex="1" parent="eferr9TLxHA396iQWkDf-14">
