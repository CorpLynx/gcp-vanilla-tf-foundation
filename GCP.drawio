          <mxGeometry x="20" y="30" width="100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="RnpZSZJgftnU-dQBf8mM-4" value="WIF Pools?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;opacity=60;" vertex="1" parent="RnpZSZJgftnU-dQBf8mM-7">
          <mxGeometry x="20" y="110" width="100" height="30" as="geometry" />
